# gRPC 服务配置
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# Go 后端代理配置
GO_PROXY_URL=http://localhost:8080/api/v1/agent-proxy

# LLM 配置
DEFAULT_MODEL=openai:gpt-4o

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Checkpointer 配置
# memory: 内存存储（开发环境，重启丢失）
# postgres: PostgreSQL 存储（生产环境，持久化）
CHECKPOINTER_TYPE=memory

# PostgreSQL 连接字符串（仅当 CHECKPOINTER_TYPE=postgres 时需要）
# POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/k8s_dashboard?sslmode=disable

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=console
